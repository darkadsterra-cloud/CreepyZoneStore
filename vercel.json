{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/creepyzone-store run build",
  "outputDirectory": "artifacts/creepyzone-store/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
